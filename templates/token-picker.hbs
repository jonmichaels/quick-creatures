<div class="qc-token-picker-window">
    <!-- Header: Set pulldown | ◀ Type ▶ | Search -->
    <div class="qc-tp-header">
        <div class="qc-tp-set-select">
            <label>SET</label>
            <select id="qc-pack-select">
                {{#each packs}}
                <option value="{{id}}" {{#if (eq id ../selectedPack)}}selected{{/if}}>{{name}}</option>
                {{/each}}
            </select>
        </div>
        <div class="qc-tp-type-nav">
            <button type="button" class="qc-tp-arrow" data-action="prev-type" aria-label="Previous type"><i class="fa-solid fa-chevron-left"></i></button>
            <span class="qc-tp-type-label">{{monsterType}}</span>
            <button type="button" class="qc-tp-arrow" data-action="next-type" aria-label="Next type"><i class="fa-solid fa-chevron-right"></i></button>
        </div>
        <div class="qc-tp-search">
            <input type="text" id="qc-token-search" placeholder="SEARCH" />
        </div>
    </div>

    {{#if showingAllTypes}}
    <!-- All types view (when current type has no tokens in this pack) -->
    <div class="qc-tp-all-types">
        {{#each allTypesTokens}}
        <div class="qc-tp-type-section">
            <h3 class="qc-tp-type-header">{{type}}</h3>
            <div class="qc-tp-grid">
                {{#each tokens}}
                <div class="qc-token-tile {{#if (eq file ../../currentTokenFile)}}selected{{/if}}" data-file="{{file}}" data-pack="{{../../selectedPack}}">
                    <div class="qc-token-tile-img">
                        <img src="{{../../modulePath}}/assets/{{../../selectedPack}}/{{file}}" alt="{{name}}" loading="lazy" />
                    </div>
                    <span class="qc-token-tile-name">{{name}}</span>
                </div>
                {{/each}}
            </div>
        </div>
        {{/each}}
    </div>
    {{else}}
    <!-- Single type grid -->
    <div class="qc-tp-grid">
        {{#each tokens}}
        <div class="qc-token-tile {{#if (eq file ../currentTokenFile)}}selected{{/if}}" data-file="{{file}}" data-pack="{{../selectedPack}}">
            <div class="qc-token-tile-img">
                <img src="{{../modulePath}}/assets/{{../selectedPack}}/{{file}}" alt="{{name}}" loading="lazy" />
            </div>
            <span class="qc-token-tile-name">{{name}}</span>
        </div>
        {{/each}}
    </div>
    {{/if}}
</div>