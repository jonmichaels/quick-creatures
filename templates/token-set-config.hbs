<section class="standard-form scrollable">
  <fieldset>
    <legend>{{localize "quick-creatures.tokenConfig.sections.defaults"}}</legend>
    <div class="form-group">
      <label>{{localize "quick-creatures.settings.defaultTokenSet.name"}}</label>
      <div class="form-fields">
        <select name="defaultTokenSet">
          {{selectOptions defaultTokenSetChoices selected=defaultTokenSet}}
        </select>
      </div>
      <p class="hint">{{localize "quick-creatures.settings.defaultTokenSet.hint"}}</p>
    </div>
    <div class="form-group">
      <label>{{localize "quick-creatures.settings.customTokenDirectory.name"}}</label>
      <div class="form-fields">
        <input type="text" name="customTokenDirectory" value="{{customTokenDirectory}}" />
        <button type="button" data-action="browseCustomDirectory" title="{{localize 'FILES.BrowseTooltip'}}"><i class="fa-solid fa-folder-open"></i></button>
      </div>
      <p class="hint">{{localize "quick-creatures.settings.customTokenDirectory.hint"}}</p>
    </div>
  </fieldset>

  <fieldset>
    <legend>{{localize "quick-creatures.tokenConfig.sections.core"}}</legend>
    {{#each coreGroup.packs}}
      <div class="form-group">
        <label for="qc-token-enabled-{{id}}">{{name}}</label>
        <div class="form-fields">
          <input id="qc-token-enabled-{{id}}" type="checkbox" name="enabled.{{id}}" {{checked enabled}} />
        </div>
      </div>
    {{/each}}
  </fieldset>

  <fieldset>
    <legend>{{localize "quick-creatures.tokenConfig.sections.pathfinder"}}</legend>
    {{#each pathfinderGroup.packs}}
      <div class="form-group">
        <label for="qc-token-enabled-{{id}}">{{name}}</label>
        <div class="form-fields">
          <input id="qc-token-enabled-{{id}}" type="checkbox" name="enabled.{{id}}" {{checked enabled}} />
        </div>
      </div>
    {{/each}}
  </fieldset>

  <fieldset>
    <legend>{{localize "quick-creatures.tokenConfig.sections.a5e"}}</legend>
    {{#each a5eGroup.packs}}
      <div class="form-group">
        <label for="qc-token-enabled-{{id}}">{{name}}</label>
        <div class="form-fields">
          <input id="qc-token-enabled-{{id}}" type="checkbox" name="enabled.{{id}}" {{checked enabled}} />
        </div>
      </div>
    {{/each}}
  </fieldset>

  <fieldset>
    <legend>{{localize "quick-creatures.tokenConfig.sections.custom"}}</legend>
    {{#if customSets.length}}
      {{#each customSets}}
        <div class="form-group">
          <label for="qc-token-custom-enabled-{{id}}">{{name}}</label>
          <div class="form-fields">
            <input id="qc-token-custom-enabled-{{id}}" type="checkbox" name="customEnabled.{{id}}" {{checked enabled}} />
          </div>
          <p class="hint">{{classification}}</p>
        </div>
      {{/each}}
    {{else}}
      <p class="hint">{{localize "quick-creatures.tokenConfig.noCustomSets"}}</p>
    {{/if}}
  </fieldset>
</section>
