<!-- Quick Creatures — two-column layout -->
<div class="qc-app">
    <!-- Left column: inputs + features + button -->
    <div class="qc-left">
        <!-- Name + Type header -->
        {{> "modules/quick-creatures/templates/partials/header.hbs"}}

        <!-- Tab content (CR or Archetype) -->
        <div class="qc-tab-content active" data-tab="tab_cr" data-group="primary">
            {{> "modules/quick-creatures/templates/partials/tab-cr.hbs"}}
        </div>
        <div class="qc-tab-content" data-tab="tab_archetype" data-group="primary">
            {{> "modules/quick-creatures/templates/partials/tab-archetype.hbs"}}
        </div>

        <!-- Feature selection -->
        {{> "modules/quick-creatures/templates/partials/features.hbs"}}

        <!-- Create button -->
        <div class="qc-footer">
            <button type="button" id="create-monster-btn" class="qc-create-btn">
                <i class="fa-solid fa-spaghetti-monster-flying"></i>
                {{i18n "create.button"}}
            </button>
        </div>
    </div>

    <!-- Right column: stat preview -->
    <div class="qc-right">
        <div class="qc-stat-preview">
            <div class="qc-token-preview">
                <img id="token-preview" src="{{modulePath}}/tokens/aberration.png" alt="{{i18n 'preview.tokenAlt'}}" />
            </div>

            <!-- Combat stats -->
            <div class="qc-stats flexrow">
                <div class="qc-stat">
                    <i class="fa-solid fa-heart"></i>
                    <span class="qc-stat-label">{{i18n "preview.hp"}}</span>
                    <span id="hpLabel">{{defaultStats.HP}}</span>
                </div>
                <div class="qc-stat">
                    <i class="fa-solid fa-shield"></i>
                    <span class="qc-stat-label">{{i18n "preview.acdc"}}</span>
                    <span id="acLabel">{{defaultStats.ACDC}}</span>
                </div>
            </div>
            <div class="qc-stats flexrow">
                <div class="qc-stat">
                    <i class="fa-solid fa-arrow-up"></i>
                    <span class="qc-stat-label">{{i18n "preview.pb"}}</span>
                    <span id="profLabel">{{defaultStats.PAB}}</span>
                </div>
                <div class="qc-stat">
                    <i class="fa-solid fa-dial"></i>
                    <span class="qc-stat-label">{{i18n "preview.level"}}</span>
                    <span id="lvlLabel">{{defaultStats.ECL}}</span>
                </div>
            </div>
            <div class="qc-stats">
                <div class="qc-stat">
                    <i class="fa-solid fa-swords"></i>
                    <span class="qc-stat-label">{{i18n "preview.damage"}}</span>
                    <span id="dmgLabel">{{defaultStats.DpACalc}} × {{defaultStats.NoA}}</span>
                </div>
            </div>
        </div>
    </div>
</div>

    <!-- Bottom bar — spanning both columns: abilities + saves -->
    <div class="qc-bottom flexrow">
        <div class="qc-abilities flexrow">
            {{#each (arr "str" "dex" "con" "int" "wis" "cha")}}
            <div class="qc-ability">
                <span class="qc-ability-label">{{i18n (concat "abilities." this)}}</span>
                <span id="{{this}}Label">+0</span>
            </div>
            {{/each}}
        </div>
        <div class="qc-saves">
            <span id="stLabel" class="qc-save-text"></span>
        </div>
    </div>
</div>
