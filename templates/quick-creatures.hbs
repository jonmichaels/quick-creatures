<!-- Quick Creatures — two-column layout -->
<div class="qc-app">
    <!-- Left column: header + size + tab content -->
    <div class="qc-left">
        <!-- Name + Type header -->
        {{> "modules/quick-creatures/templates/partials/header.hbs"}}

        <!-- Size selector (visible on both tabs) -->
        <div class="qc-size-select">
            <label for="creature-size">{{i18n "create.sizeLabel"}}</label>
            <select id="creature-size" name="size">
                {{#each sizes}}
                <option value="{{this}}" {{#if (eq this ../defaults.size)}}selected{{/if}}>{{this}}</option>
                {{/each}}
            </select>
        </div>

        <div class="qc-tab-content active" data-tab="tab_cr" data-group="primary">
            {{> "modules/quick-creatures/templates/partials/tab-cr.hbs"}}
        </div>
        <div class="qc-tab-content" data-tab="tab_archetype" data-group="primary">
            {{> "modules/quick-creatures/templates/partials/tab-archetype.hbs"}}
        </div>
    </div>

    <!-- Right column: token + stats side by side -->
    <div class="qc-right">
        <div class="qc-stat-preview flexrow">
            <div class="qc-token-preview">
                <img id="token-preview" src="{{tokenPreviewSrc}}" alt="{{i18n 'preview.tokenAlt'}}" />
                <label class="qc-dynamic-ring">
                    <input type="checkbox" id="dynamic-ring" {{#if defaults.dynamicRing}}checked{{/if}} />
                    <span>{{i18n "preview.dynamicRing"}}</span>
                </label>
            </div>

            <div class="qc-stats-grid">
                <div class="qc-stat qc-adjustable-stat" data-stat="hp">
                    <span class="qc-stat-label">{{i18n "preview.hp"}}</span>
                    <div class="qc-stat-adjust-row">
                        <button type="button" class="qc-advanced-control qc-adjust-minus" data-adjust="hp" data-direction="-1" data-tooltip="-10%"><i class="fa-solid fa-minus"></i></button>
                        <span id="hpLabel" class="qc-adjust-value" data-reset-adjust="hp">{{defaultStats.HP}}</span>
                        <button type="button" class="qc-advanced-control qc-adjust-plus" data-adjust="hp" data-direction="1" data-tooltip="+10%"><i class="fa-solid fa-plus"></i></button>
                    </div>
                </div>
                <div class="qc-stat qc-adjustable-stat" data-stat="ac">
                    <span class="qc-stat-label">{{i18n "preview.acdc"}}</span>
                    <div class="qc-stat-adjust-row">
                        <button type="button" class="qc-advanced-control qc-adjust-minus" data-adjust="ac" data-direction="-1" data-tooltip="-10%"><i class="fa-solid fa-minus"></i></button>
                        <span id="acLabel" class="qc-adjust-value" data-reset-adjust="ac">{{defaultStats.ACDC}}</span>
                        <button type="button" class="qc-advanced-control qc-adjust-plus" data-adjust="ac" data-direction="1" data-tooltip="+10%"><i class="fa-solid fa-plus"></i></button>
                    </div>
                </div>
                <div class="qc-stat">
                    <span class="qc-stat-label">{{i18n "preview.pb"}}</span>
                    <span id="profLabel">{{defaultStats.PAB}}</span>
                </div>
                <div class="qc-stat qc-adjustable-stat" data-stat="damage">
                    <span class="qc-stat-label">{{i18n "preview.damage"}}</span>
                    <div class="qc-stat-adjust-row">
                        <button type="button" class="qc-advanced-control qc-adjust-minus" data-adjust="damage" data-direction="-1" data-tooltip="-10%"><i class="fa-solid fa-minus"></i></button>
                        <span id="dmgLabel" class="qc-adjust-value" data-reset-adjust="damage">{{defaultStats.DpACalc}} &times;{{defaultStats.NoA}}</span>
                        <button type="button" class="qc-advanced-control qc-adjust-plus" data-adjust="damage" data-direction="1" data-tooltip="+10%"><i class="fa-solid fa-plus"></i></button>
                    </div>
                </div>
            </div>
        </div>

        <div class="qc-tab-content qc-archetype-desc" data-tab="tab_archetype">
            <p id="archetype-desc" data-tooltip="">
                {{#if firstArchetype.short}}{{firstArchetype.short}}{{else if firstArchetype.desc}}{{firstArchetype.desc}}{{/if}}
            </p>
        </div>
    </div>

    <!-- Combined Ability Scores (spans both columns) -->
    <div class="qc-abilities-section">
        <div class="qc-abilities-row flexrow">
            {{#each (arr "str" "dex" "con" "int" "wis" "cha")}}
            <div class="qc-ability-col">
                <span class="qc-ability-label">{{i18n (concat "abilities." this)}}</span>
                <div class="qc-ability-adjust-row">
                    <button type="button" class="qc-advanced-control qc-adjust-minus" data-adjust="ability" data-ability="{{this}}" data-direction="-1"><i class="fa-solid fa-minus"></i></button>
                    <span id="{{this}}Label" class="qc-ability-mod qc-adjust-value" data-reset-adjust="ability" data-ability="{{this}}">+0</span>
                    <button type="button" class="qc-advanced-control qc-adjust-plus" data-adjust="ability" data-ability="{{this}}" data-direction="1"><i class="fa-solid fa-plus"></i></button>
                </div>
                <div class="qc-tab-content active" data-tab="tab_cr">
                    <span class="qc-ability-toggle" data-state="off" data-ability="{{this}}" role="checkbox" aria-checked="false"></span>
                </div>
            </div>
            {{/each}}
        </div>
        <div class="qc-tab-content active" data-tab="tab_cr">
            <p class="qc-abilities-hint">Check one or two primary abilities. (<span id="saveBonus">+2</span>) Optional: two or three secondary. (<span id="halfPbLabel">+1</span>)</p>
        </div>
    </div>

    <!-- Creature Features (spans both columns) -->
    <div class="qc-features-section">
        {{> "modules/quick-creatures/templates/partials/features.hbs"}}
    </div>

    <!-- Create button (spans both columns, last item on page) -->
    <div class="qc-create-section">
        <div class="qc-create-left">
            <div class="qc-tab-content active" data-tab="tab_cr">
                <label class="qc-advanced-toggle">
                    <input type="checkbox" id="advanced-mode" {{#if advancedMode}}checked{{/if}} />
                    <span>{{i18n "advanced.label"}}</span>
                </label>
            </div>
            <button type="button" id="qc-credits-btn" class="qc-credits-btn" data-tooltip="Credits">
                <i class="fa-solid fa-copyright"></i>
            </button>
        </div>
        <button type="button" id="create-monster-btn" class="qc-create-btn">
            {{i18n "create.button"}}
        </button>
    </div>
</div>
