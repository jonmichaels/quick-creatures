<!-- Archetype tab — select + description -->
<div class="qc-tab-panel">
    <div class="form-group">
        <label for="archetype-select">Archetype</label>
        <select id="archetype-select" name="archetype">
            {{#each archetypes}}
            <option value="{{name}}" data-stats="{{serialized}}">
                {{name}} (CR {{CR}})
            </option>
            {{/each}}
        </select>
    </div>
</div>
